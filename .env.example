# ─────────────────────────────────────────────
# COPIA ESTE ARCHIVO A .env.local Y RELLÉNALO
# NUNCA subas .env.local a Git
# ─────────────────────────────────────────────

# Base de datos PostgreSQL (Docker local)
DATABASE_URL="postgresql://postgres:password_segura@localhost:5432/edularp"

# NextAuth — Autenticación
# Genera el secret con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia_esto_por_un_secreto_largo_aleatorio"
NEXTAUTH_URL="http://localhost:3000"
# Detrás de un proxy SSL que termina HTTPS (ej. UC3M), mantener en false.
# Las cookies __Secure- requieren secure:true; si el proxy termina SSL internamente
# deben usarse sin ese prefijo. En despliegue directo HTTPS, cambiar a true.
NEXTAUTH_SECURE=false

# Anthropic — Motor principal del chatbot
# Obtén tu clave en https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-api03-CHANGE_ME"

# Groq — Motor de fallback del chatbot
# Obtén tu clave en https://console.groq.com
GROQ_API_KEY="gsk_CHANGE_ME"

# Ollama — Fallback local sin límite de tasa (opcional)
# Asegúrate de tener ollama instalado y el modelo nomic-embed-text descargado
OLLAMA_URL="http://localhost:11434"

# Archivos subidos por los docentes
UPLOAD_DIR="./public/uploads"

# Orígenes permitidos para Server Actions de Next.js (separados por coma)
# Añade la IP y dominio públicos del servidor de producción
ALLOWED_ORIGINS="163.117.137.118,dei.inf.uc3m.es"

# Secret para autenticar llamadas internas entre rutas API
# Genera con: openssl rand -hex 32
INTERNAL_API_SECRET="cambia_esto_por_un_secreto_aleatorio_de_32_chars"

# Email para notificaciones (opcional en desarrollo)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="tu_email@gmail.com"
# SMTP_PASS="tu_app_password"
# SMTP_FROM="EduLARP <notificaciones@tudominio.es>"

# URL pública en producción
# NEXTAUTH_URL="https://dei.inf.uc3m.es/techlarp-chatbot"
